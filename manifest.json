{
  "manifest_version": 3,
  "default_locale": "de",
  "name": "__MSG_extensionName__",
  "version": "6",
  "description": "__MSG_extensionDescription__",
  "homepage_url": "https://github.com/mykhaylo-zhovkevych/dictionary-plus-mz/",
  "icons": {
    "48": "icons/IconDict48.ico",
    "256": "icons/IconDict256.ico",
    "512": "icons/IconDict512.ico"
  },

  "permissions": [
    "menus",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://uk.search.yahoo.com/*",
    "https://search.yahoo.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "48": "icons/IconDict48.ico"
    },
    "default_title": "__MSG_actionBtnTitle__"
  },
  "options_ui": {
    "page": "options/options.html"
  }
}
